{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Template-Proj-Tauri-Menu",
  "version": "0.1.0",
  "identifier": "com.template.tauri-menu",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Template-Proj-Tauri-Menu",
        "width": 1024,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480,
        "maximized": true,
        "decorations": false,
        "transparent": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
